# Virtual Environments
.venv/
venv/
env/

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / Packaging
dist/
build/
*.egg-info/


# Ignore raw textbooks and temporary cleaning folders
data/raw_dataset/
data/cleaned_dataset/

# Step 1: Ignore everything inside the data folder
data/*

# Step 2: Allow ONLY the processed vector store files
# If your files are directly in data/
!data/index.faiss
!data/index.pkl

# If your files are in a subfolder
!data/vector_store/
!data/vector_store/**

# Streamlit configuration and credentials
.streamlit/
! .streamlit/config.toml

# Ignore temporary demo recordings or screenshots
*.webm
*.mp4
*.png
*.jpg


# Ignore local LLM weights or heavy embedding models
*.bin
*.pt
*.onnx
*.gguf

# Logs and temporary databases
*.log
*.sqlite3
.DS_Store


.vscode/
.idea/
*.swp
*.tmp
*.bak
